{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ConfirmCarbontraceActiveWorkloadLease",
      "Effect": "Allow",
      "Action": "ec2:DescribeInstances",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    },
    {
      "Sid": "PublishOnlyCarbontraceMetrics",
      "Effect": "Allow",
      "Action": "cloudwatch:PutMetricData",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "cloudwatch:namespace": [
            "Carbontrace/App",
            "Carbontrace/Host"
          ]
        }
      }
    },
    {
      "Sid": "ManageOnlyCarbontraceActiveWorkloadLease",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateTags",
        "ec2:DeleteTags"
      ],
      "Resource": "arn:aws:ec2:us-east-1:<AWS_ACCOUNT_ID>:instance/*",
      "Condition": {
        "ForAllValues:StringEquals": {
          "aws:TagKeys": [
            "CarbontraceActiveUntil"
          ]
        },
        "StringEquals": {
          "ec2:ResourceTag/Name": "carbontrace-profiler",
          "ec2:ResourceTag/Project": "Carbontrace"
        }
      }
    },
    {
      "Sid": "WriteOnlyCarbontraceApplicationLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:DescribeLogStreams",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:<AWS_ACCOUNT_ID>:log-group:/aws/carbontrace/carbontrace:*"
    }
  ]
}
