{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublishOnlyCarbontraceMetrics",
      "Effect": "Allow",
      "Action": "cloudwatch:PutMetricData",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "cloudwatch:namespace": [
            "Carbontrace/App",
            "Carbontrace/Host"
          ]
        }
      }
    },
    {
      "Sid": "WriteOnlyCarbontraceApplicationLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:DescribeLogStreams",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:562325340670:log-group:/aws/carbontrace/carbontrace:*"
    }
  ]
}
