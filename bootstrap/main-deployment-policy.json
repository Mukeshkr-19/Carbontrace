{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadUsEast1Infrastructure",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeAccountAttributes",
        "ec2:DescribeAvailabilityZones",
        "ec2:DescribeImages",
        "ec2:DescribeInstanceAttribute",
        "ec2:DescribeInstanceCreditSpecifications",
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus",
        "ec2:DescribeInstanceTypes",
        "ec2:DescribeKeyPairs",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeSubnets",
        "ec2:DescribeTags",
        "ec2:DescribeVolumes",
        "ec2:DescribeVpcAttribute",
        "ec2:DescribeVpcs",
        "logs:DescribeLogGroups"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    },
    {
      "Sid": "ReadCallerIdentity",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReadExactRuntimeRoles",
      "Effect": "Allow",
      "Action": [
        "iam:GetRole",
        "iam:ListRoleTags"
      ],
      "Resource": [
        "arn:aws:iam::562325340670:role/carbontrace-ec2-role",
        "arn:aws:iam::562325340670:role/carbontrace-auto-stop-role"
      ]
    },
    {
      "Sid": "ReadExactEc2InstanceProfile",
      "Effect": "Allow",
      "Action": [
        "iam:GetInstanceProfile",
        "iam:ListInstanceProfileTags"
      ],
      "Resource": "arn:aws:iam::562325340670:instance-profile/carbontrace-ec2-profile"
    },
    {
      "Sid": "LaunchOnlyCostBoundedProfilerInstance",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances"
      ],
      "Resource": "arn:aws:ec2:us-east-1:562325340670:instance/*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/Project": "Carbontrace",
          "ec2:InstanceType": "t3.micro"
        }
      }
    },
    {
      "Sid": "UseRequiredEc2LaunchResources",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances"
      ],
      "Resource": [
        "arn:aws:ec2:us-east-1::image/*",
        "arn:aws:ec2:us-east-1:562325340670:key-pair/*",
        "arn:aws:ec2:us-east-1:562325340670:network-interface/*",
        "arn:aws:ec2:us-east-1:562325340670:security-group/*",
        "arn:aws:ec2:us-east-1:562325340670:subnet/*",
        "arn:aws:ec2:us-east-1:562325340670:volume/*"
      ]
    },
    {
      "Sid": "CreateCarbontraceSecurityGroup",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSecurityGroup"
      ],
      "Resource": [
        "arn:aws:ec2:us-east-1:562325340670:security-group/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/Project": "Carbontrace"
        }
      }
    },
    {
      "Sid": "UseVpcForCarbontraceSecurityGroupCreation",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSecurityGroup"
      ],
      "Resource": [
        "arn:aws:ec2:us-east-1:562325340670:vpc/*"
      ]
    },
    {
      "Sid": "ManageOnlyCarbontraceSecurityGroups",
      "Effect": "Allow",
      "Action": [
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:DeleteSecurityGroup",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupIngress"
      ],
      "Resource": "arn:aws:ec2:us-east-1:562325340670:security-group/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/Project": "Carbontrace"
        }
      }
    },
    {
      "Sid": "StopOrTerminateOnlyCarbontraceInstances",
      "Effect": "Allow",
      "Action": [
        "ec2:StopInstances",
        "ec2:TerminateInstances"
      ],
      "Resource": "arn:aws:ec2:us-east-1:562325340670:instance/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/Project": "Carbontrace"
        }
      }
    },
    {
      "Sid": "TagResourcesOnlyDuringCarbontraceCreation",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateTags"
      ],
      "Resource": [
        "arn:aws:ec2:us-east-1:562325340670:instance/*",
        "arn:aws:ec2:us-east-1:562325340670:security-group/*",
        "arn:aws:ec2:us-east-1:562325340670:volume/*"
      ],
      "Condition": {
        "ForAllValues:StringEquals": {
          "aws:TagKeys": [
            "ManagedBy",
            "Name",
            "Project"
          ]
        },
        "StringEquals": {
          "aws:RequestTag/Project": "Carbontrace",
          "ec2:CreateAction": [
            "CreateSecurityGroup",
            "RunInstances"
          ]
        }
      }
    },
    {
      "Sid": "PassCarbontraceEc2RoleOnly",
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": "arn:aws:iam::562325340670:role/carbontrace-ec2-role",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ec2.amazonaws.com"
        }
      }
    },
    {
      "Sid": "PassCarbontraceLambdaRoleOnly",
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": "arn:aws:iam::562325340670:role/carbontrace-auto-stop-role",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "lambda.amazonaws.com"
        }
      }
    },
    {
      "Sid": "ManageCarbontraceLogGroups",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:DeleteLogGroup",
        "logs:PutRetentionPolicy"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:562325340670:log-group:/aws/carbontrace/carbontrace",
        "arn:aws:logs:us-east-1:562325340670:log-group:/aws/carbontrace/carbontrace:*",
        "arn:aws:logs:us-east-1:562325340670:log-group:/aws/lambda/carbontrace-auto-stop",
        "arn:aws:logs:us-east-1:562325340670:log-group:/aws/lambda/carbontrace-auto-stop:*"
      ]
    },
    {
      "Sid": "TagCarbontraceLogGroups",
      "Effect": "Allow",
      "Action": [
        "logs:ListTagsForResource",
        "logs:TagResource",
        "logs:UntagResource"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:562325340670:log-group:/aws/carbontrace/carbontrace",
        "arn:aws:logs:us-east-1:562325340670:log-group:/aws/lambda/carbontrace-auto-stop"
      ]
    },
    {
      "Sid": "ManageCarbontraceDashboard",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:DeleteDashboards",
        "cloudwatch:GetDashboard",
        "cloudwatch:ListTagsForResource",
        "cloudwatch:PutDashboard",
        "cloudwatch:TagResource",
        "cloudwatch:UntagResource"
      ],
      "Resource": "arn:aws:cloudwatch::562325340670:dashboard/carbontrace-dashboard"
    },
    {
      "Sid": "ManageCarbontraceAutoStopFunction",
      "Effect": "Allow",
      "Action": [
        "lambda:AddPermission",
        "lambda:CreateFunction",
        "lambda:DeleteFunction",
        "lambda:GetFunction",
        "lambda:GetFunctionCodeSigningConfig",
        "lambda:GetFunctionConfiguration",
        "lambda:GetPolicy",
        "lambda:ListTags",
        "lambda:ListVersionsByFunction",
        "lambda:RemovePermission",
        "lambda:TagResource",
        "lambda:UntagResource",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration"
      ],
      "Resource": "arn:aws:lambda:us-east-1:562325340670:function:carbontrace-auto-stop"
    },
    {
      "Sid": "ManageCarbontraceAutoStopAlarm",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:DeleteAlarms",
        "cloudwatch:DescribeAlarms",
        "cloudwatch:ListTagsForResource",
        "cloudwatch:PutMetricAlarm",
        "cloudwatch:TagResource",
        "cloudwatch:UntagResource"
      ],
      "Resource": "arn:aws:cloudwatch:us-east-1:562325340670:alarm:carbontrace-auto-stop-errors"
    },
    {
      "Sid": "ManageCarbontraceAutoStopSchedule",
      "Effect": "Allow",
      "Action": [
        "events:DeleteRule",
        "events:DescribeRule",
        "events:ListTagsForResource",
        "events:ListTargetsByRule",
        "events:PutRule",
        "events:PutTargets",
        "events:RemoveTargets",
        "events:TagResource",
        "events:UntagResource"
      ],
      "Resource": "arn:aws:events:us-east-1:562325340670:rule/carbontrace-auto-stop"
    }
  ]
}
